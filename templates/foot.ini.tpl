[main]
font=JetBrainsMono Nerd Font:size=10
pad=12x8
selection-target=clipboard

[url]
launch=google-chrome-stable ${url}

[key-bindings]
show-urls-launch=Control+Shift+o

[colors]
alpha=0.92
foreground=${text}
background=${base}
cursor=${base} ${text}

regular0=${ansi_black}
regular1=${ansi_red}
regular2=${ansi_green}
regular3=${ansi_yellow}
regular4=${ansi_blue}
regular5=${ansi_magenta}
regular6=${ansi_cyan}
regular7=${ansi_white}

bright0=${ansi_brblack}
bright1=${ansi_brred}
bright2=${ansi_brgreen}
bright3=${ansi_bryellow}
bright4=${ansi_brblue}
bright5=${ansi_brmagenta}
bright6=${ansi_brcyan}
bright7=${ansi_brwhite}
